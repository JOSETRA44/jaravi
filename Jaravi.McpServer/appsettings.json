{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Urls": "http://localhost:5210",
  "Engine": {
    "AllowedRoots": [
      "C:\\Users\\USER\\source"
    ],
    "MaxConcurrentSessions": 8,
    "MaxReadLines": 500,
    "LogBufferCapacity": 10000,
    "WatchdogIntervalMs": 5000
  }
}
